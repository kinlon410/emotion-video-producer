# Emotion Video Producer - Environment Variables Example
# Copy this file to .env and fill in your values
# Never commit your real .env file or any plaintext API key

# ── Required API Keys ──

# Alibaba Qwen API Key (for AI narrative generation + TTS + ASR)
# Get from: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# Moss API Key (optional TTS provider)
MOSS_API_KEY=

# Pexels API Key (for video stock footage download)
# Get from: https://www.pexels.com/api/
PEXELS_API_KEY=

# Pixabay API Key (backup video source)
# Get from: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# ── Optional: Local CosyVoice TTS ──

# CosyVoice code directory (for local TTS)
# Download from: https://github.com/FunAudioLLM/CosyVoice
COSYVOICE_PATH=

# CosyVoice model directory
# Download from: https://huggingface.co/FunAudioLLM
COSYVOICE_MODEL_DIR=

# ── System Dependencies ──

# FFmpeg (required for video processing)
# macOS: brew install ffmpeg
# Linux: apt install ffmpeg
# Windows: download from https://ffmpeg.org/download.html
